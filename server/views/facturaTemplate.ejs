<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Factura Electrónica - <%= factura.id %></title>
    <!-- Incluir Bootstrap 5 via CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; background: #fff; }
        .invoice-card { padding: 40px; }
        .invoice-header { border-bottom: 2px solid #0d6efd; padding-bottom: 20px; }
        .logo-img { max-height: 80px; }
        .company-info { font-size: 0.9rem; color: #555; }
        .invoice-title { font-weight: 800; color: #0d6efd; letter-spacing: 1px; }
        .qr-box img { max-width: 120px; border: 1px solid #ddd; border-radius: 8px; padding: 5px; }
        
        .table-custom th { background-color: #f8f9fa; color: #333; font-weight: 700; text-transform: uppercase; font-size: 12px; }
        .table-custom td { vertical-align: middle; font-size: 13px; }
        
        .totals-box { background: #f8f9fa; border-radius: 8px; padding: 20px; }
        .total-row { font-size: 18px; font-weight: 800; color: #0d6efd; border-top: 2px solid #dee2e6; margin-top: 10px; padding-top: 10px; }
        
        .status-badge { display: inline-block; padding: 5px 12px; border-radius: 50px; font-size: 12px; font-weight: bold; text-transform: uppercase; }
        .status-emitida { background-color: #e8f5e9; color: #2e7d32; border: 1px solid #a5d6a7; }
        .status-cancelada { background-color: #ffebee; color: #c62828; border: 1px solid #ef9a9a; }
        
        /* Ocultar elementos en PDF margins etc if needed, Puppeteer maneja los paddings propios */
    </style>
</head>
<body>

<div class="container-fluid invoice-card">
    
    <!-- ENCABEZADO -->
    <div class="row invoice-header mb-4">
        <div class="col-6">
            <img src="<%= logoUrl %>" alt="Logo Empresa" class="logo-img mb-3">
            <div class="company-info">
                <strong>EPRESEDI S.A.S.</strong><br>
                NIT: 900.123.456-7<br>
                Dirección Principal, Edificio Central<br>
                Bogotá, Colombia<br>
                Tel: +57 320 000 0000<br>
                correo: contacto@epresedi.com
            </div>
        </div>
        <div class="col-6 text-end">
            <h1 class="invoice-title">FACTURA DE VENTA</h1>
            <h3 class="mb-3 text-secondary"># <%= factura.id %></h3>
            
            <div class="text-start d-inline-block bg-light p-3 rounded shadow-sm">
                <table class="table table-borderless table-sm mb-0 company-info">
                    <tr><td class="text-muted fw-bold">Fecha de Emisión:</td><td class="text-end"><%= factura.fecha %></td></tr>
                    <tr><td class="text-muted fw-bold">Vencimiento:</td><td class="text-end"><%= factura.fecha %></td></tr>
                    <tr><td class="text-muted fw-bold">Estado:</td>
                        <td class="text-end">
                            <span class="status-badge <%= factura.estado === 'emitida' ? 'status-emitida' : 'status-cancelada' %>">
                                <%= factura.estado || 'EMITIDA' %>
                            </span>
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <!-- DATOS DEL CLIENTE -->
    <div class="row mb-4">
        <div class="col-12">
            <h5 class="fw-bold mb-3 border-bottom pb-2">Información del Cliente</h5>
            <div class="row company-info">
                <div class="col-6">
                    <strong>Cliente / Razón Social:</strong><br>
                    <span class="fs-6 text-dark"><%= factura.cliente %></span>
                </div>
                <div class="col-6">
                    <strong>NIT / Identificación:</strong><br>
                    <span class="fs-6 text-dark"><%= factura.nit %></span>
                </div>
            </div>
        </div>
    </div>

    <!-- DETALLE DE PRODUCTOS -->
    <div class="row mb-5">
        <div class="col-12">
            <table class="table table-hover table-custom border">
                <thead>
                    <tr>
                        <th width="15%">CÓDIGO</th>
                        <th width="45%">DESCRIPCIÓN</th>
                        <th width="10%" class="text-center">CANT.</th>
                        <th width="15%" class="text-end">P. UNITARIO</th>
                        <th width="15%" class="text-end">SUBTOTAL</th>
                    </tr>
                </thead>
                <tbody>
                    <% factura.items.forEach(function(item) { %>
                    <tr>
                        <td class="font-monospace"><%= item.codigo %></td>
                        <td><%= item.descripcion %></td>
                        <td class="text-center"><%= item.cantidad %></td>
                        <td class="text-end">$<%= Number(item.valorUnitario).toLocaleString('es-CO', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></td>
                        <td class="text-end fw-bold">$<%= Number(item.total).toLocaleString('es-CO', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- TOTALES Y QR -->
    <div class="row">
        <!-- Lado izquierdo: QR e Info -->
        <div class="col-7">
            <h6 class="fw-bold mb-3">Información Adicional</h6>
            <p class="company-info small text-muted">Esta factura de venta se asimila en todos sus efectos a una letra de cambio.<br> El pago debe realizarse mediante consignación a la cuenta bancaria autorizada.</p>
            
            <div class="mt-4 qr-box d-flex align-items-center gap-3">
                <img src="<%= qrImage %>" alt="QR Code">
                <div class="small text-muted">
                    Escanea el código QR para validar la<br> autenticidad de este documento en<br> nuestros servidores corporativos.
                </div>
            </div>
        </div>
        
        <!-- Lado derecho: Totales -->
        <div class="col-5">
            <div class="totals-box">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted fw-bold">Subtotal Base:</span>
                    <span>$<%= Number(factura.total).toLocaleString('es-CO', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted fw-bold">IVA (0%):</span>
                    <span>$0.00</span>
                </div>
                <div class="d-flex justify-content-between total-row">
                    <span>TOTAL A PAGAR:</span>
                    <span>$<%= Number(factura.total).toLocaleString('es-CO', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <div class="row mt-5 pt-4 border-top">
        <div class="col-12 text-center text-muted small">
            Generado electrónicamente por el Sistema EPRESEDI S.A.S.<br>
            Documento sin validez fiscal si no cuenta con firmas autorizadas.
        </div>
    </div>

</div>

</body>
</html>
